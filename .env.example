# GnosIQ — Environment Variables
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no repositório

# Vercel (não necessário em .env.local — usados pelo CI/CD)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# GCP / Firebase
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# Stripe (M2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI APIs (M2)
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
